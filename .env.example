# Root .env — only used by docker-compose to configure the `postgres`
# container (image needs POSTGRES_USER/PASSWORD/DB, not Spring's var names).
#
# These 3 values MUST match what's already in back_end/.env:
#   DB_USERNAME / DB_PASSWORD here == DB_USERNAME / DB_PASSWORD in back_end/.env
#   DB_NAME here == the database name in back_end/.env's DB_URL
#   (e.g. DB_URL=jdbc:postgresql://postgres:5432/DATN -> DB_NAME=DATN)
#
# Copy this file to `.env` (git-ignored) and fill in the real values before
# running `docker compose up`.
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
